# ===========================================
# springMall Docker 部署环境变量模板
# 复制此文件: cp .env.example .env.test 或 .env.prod
# ===========================================

# ---- 端口映射（宿主机端口） ----
BACKEND_PORT=25116
FRONTEND_PORT=26115
MYSQL_PORT=3306
REDIS_PORT=6379
RABBITMQ_MGMT_PORT=15672

# ---- 数据库 ----
# Docker Compose 内部通信使用服务名 "mysql"，无需修改
DB_HOST=mysql
DB_PORT=3306
DB_NAME=mall
DB_USERNAME=root
DB_PASSWORD=test123456

# ---- JWT ----
# 生产环境请使用足够长的随机字符串（至少 64 字符，Base64 编码）
JWT_SECRET=b8b43825c73deda2de001ac790281b9e7de2644220c1e5afa412f59f02c3efd5

# ---- Redis ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=123456

# ---- RabbitMQ ----
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=123456

# ---- 支付宝 ----
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=
ALIPAY_RETURN_URL=
FRONTEND_URL=http://localhost:3000

# ---- Stripe ----
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_REFUND_WEBHOOK_SECRET=
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
STRIPE_TEST_MODE=true
PRODUCT_IMAGE_BASE_URL=

# ---- XXL-JOB ----
XXL_JOB_ADMIN_PORT=8088
XXL_JOB_ADMIN_ADDRESSES=http://xxl-job-admin:8080/xxl-job-admin
# [安全要求] 生产环境必须设置为随机字符串，空值将导致 admin 与 executor 无认证通信
XXL_JOB_ACCESS_TOKEN=
XXL_JOB_EXECUTOR_PORT=9999
